        <div class="memory__grid" data-memory-grid>
          <button type="button" class="memory__card" data-memory-card data-value="apple">
            <span class="memory__card-inner">
              <span class="memory__card-face memory__card-face--back">❓</span>
              <span class="memory__card-face memory__card-face--front">🍎</span>

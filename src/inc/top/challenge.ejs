    <div class="challenge__row">
      <div class="challenge__game" data-quiz-game>
        <h3>🎁 Đố vui nhận sticker</h3>
        <p class="challenge__question">Con vật nào sau đây biết bay?</p>

        <div class="challenge__options">
          <button type="button" class="challenge__option" data-quiz-option data-correct="false">🐢 Rùa</button>
          <button type="button" class="challenge__option" data-quiz-option data-correct="true">🦋 Bướm</button>
          <button type="button" class="challenge__option" data-quiz-option data-correct="false">🐟 Cá</button>

<%
  const books = [
    {
      age: 'mamnon',
      badge: 'Mầm non (2-5t)',
      title: 'Ehon: Bé Yêu Động Vật',
      desc: 'Hình ảnh sinh động, giúp bé nhận biết các loài vật quen thuộc qua từng trang lật mở.',
      image: '/assets/images/book-mamnon-1.svg',
    },
    {
      age: 'lop12',
      badge: 'Lớp 1-2 (6-7t)',
      title: 'Truyện Tranh Giáo Dục - Bé Tập Đọc',
      desc: 'Chữ to, có phiên âm rõ ràng giúp bé rèn luyện kỹ năng đọc rành mạch mỗi ngày.',
      image: '/assets/images/book-lop12-1.svg',
    },
    {
      age: 'lop35',
      badge: 'Lớp 3-5 (8-10t)',
      title: 'Nhà Khoa Học Tí Hòn - Vũ Trụ Bao La',
      desc: 'Giúp bé hiểu về các hành tinh qua câu chuyện minh hoạ sặc sỡ.',
      image: '/assets/images/book-lop35-1.svg',
    },
    {
      age: 'lop12',
      badge: 'Lớp 1-2 (6-7t)',
      title: 'Luyện Viết Chữ Đẹp Theo Dòng Ô Li (Tập 1)',
      desc: 'Ô li chuẩn 2x2mm, giấy chống lóa OE 80gsm - đọc review chi tiết trước khi chọn mua cho bé.',
      image: '/assets/images/book-lop12-1.svg',
    },
  ];
  const reviewLink = '/sach/review/index.html?id=luyen-viet-chu-dep-o-li';
%>
<section class="bookshelf">
  <div class="bookshelf__inner">
    <div class="bookshelf__header">
      <h2 class="bookshelf__title">📚 Tủ Sách Hay Cho Bé</h2>
      <p class="bookshelf__subtitle">Tổng hợp những cuốn sách được tuyển chọn kỹ lưỡng cùng các bài review chi tiết, giúp bố mẹ dễ dàng chọn đúng cuốn sách đồng hành cùng con trong từng giai đoạn phát triển.</p>
    </div>

    <div class="bookshelf__grid" data-book-grid>
      <% books.forEach((book) => { %>
        <article
          class="bookshelf__card"
          data-book-preview
          data-book-age="<%= book.age %>"
          data-review-link="<%= reviewLink %>"
          role="button"
          tabindex="0"
        >
          <div class="bookshelf__cover">
            <img src="<%= book.image %>" alt="<%= book.title %>">
          </div>
          <span class="bookshelf__badge"><%= book.badge %></span>
          <h3 class="bookshelf__card-title"><%= book.title %></h3>
          <p class="bookshelf__card-desc"><%= book.desc %></p>
        </article>
      <% }); %>
    </div>

    <div class="bookshelf__more">
      <a class="btn" href="/sach/index.html">Xem tất cả tủ sách →</a>
    </div>

    <div class="bookshelf__banner">
      <span>💡 Gợi ý sách theo tháng - Ưu đãi combo sách + bài tập PDF</span>
    </div>
  </div>
</section>

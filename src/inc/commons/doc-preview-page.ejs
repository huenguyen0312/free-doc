<!-- Page xem trước tài liệu (mở từ doc-card qua tab mới), nội dung được main.js đọc từ query string -->
<section class="doc-preview-page">
  <div class="doc-preview-page__inner">
    <h1 class="doc-preview-page__title" data-doc-preview-page-title>Đang tải tài liệu...</h1>

    <iframe class="doc-preview-page__pdf" data-doc-preview-page-pdf title="Xem trước tài liệu"></iframe>

    <p class="doc-preview-page__desc" data-doc-preview-page-desc></p>

    <div class="doc-preview-page__actions">
      <button type="button" class="doc-preview-page__download" data-doc-preview-page-download>⬇ Tải file</button>
    </div>
  </div>
</section>

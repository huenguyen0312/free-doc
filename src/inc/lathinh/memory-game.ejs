<section class="memory-page">
  <div class="memory-page__inner">
    <h1 class="memory-page__title">🧩 Lật Hình Tìm Cặp</h1>
    <p class="memory-page__desc">Rèn luyện trí nhớ cho bé — cấp độ càng cao, số lượng hình cần nhớ càng nhiều!</p>

    <div class="memory-page__levels" data-memory-levels>
      <button type="button" class="memory-page__level-btn" data-memory-level="1">Cấp 1</button>
      <button type="button" class="memory-page__level-btn" data-memory-level="2">Cấp 2</button>
      <button type="button" class="memory-page__level-btn" data-memory-level="3">Cấp 3</button>
      <button type="button" class="memory-page__level-btn" data-memory-level="4">Cấp 4</button>
      <button type="button" class="memory-page__level-btn" data-memory-level="5">Cấp 5</button>
      <button type="button" class="memory-page__level-btn" data-memory-level="6">Cấp 6</button>
    </div>

    <p class="memory-page__status" data-memory-status></p>

    <div class="memory-page__grid" data-memory-page-grid></div>

    <p class="memory-page__result" data-memory-page-result hidden></p>
  </div>
</section>

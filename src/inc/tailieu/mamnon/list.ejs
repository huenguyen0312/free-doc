<%
  const worksheets = [
    { title: 'Bài tập phân loại', desc: 'Giúp bé rèn kỹ năng phân loại đồ vật theo màu sắc, hình dạng, kích thước.', tags: ['toan'] },
    { title: 'Luyện tập làm quen về thời gian', desc: 'Làm quen với khái niệm buổi sáng, trưa, chiều, tối và các mốc thời gian đơn giản.', tags: ['toan'] },
    { title: 'Mê cung: tinh mắt tìm đường', desc: 'Rèn sự tập trung và khả năng quan sát qua các mê cung thú vị.', tags: ['toan'] },
    { title: 'Tinh mắt tìm bóng', desc: 'Ghép hình với bóng tương ứng để rèn khả năng quan sát.', tags: ['toan'] },
    { title: 'Tinh mắt tìm điểm khác nhau', desc: 'Tìm ra những điểm khác biệt giữa hai bức tranh giống nhau.', tags: ['toan'] },
    { title: 'Quy luật cắt dán', desc: 'Luyện tay khéo léo qua các bài tập cắt, dán theo mẫu.', tags: ['to-mau'] },
    { title: 'Căn bằng nào trái, phải', desc: 'Nhận biết hướng trái, phải qua các bài tập trực quan sinh động.', tags: ['toan'] },
    { title: 'Luyện tập so sánh ít nhiều', desc: 'Rèn tư duy so sánh số lượng nhiều - ít giữa các nhóm đồ vật.', tags: ['toan'] },
    { title: 'Luyện tập so sánh to nhỏ, cao thấp, nặng nhẹ, dài ngắn', desc: 'So sánh các đặc điểm kích thước cơ bản của sự vật xung quanh bé.', tags: ['toan'] },
    { title: 'Luyện tập làm quen hình học', desc: 'Nhận biết các hình khối cơ bản: tròn, vuông, tam giác, chữ nhật.', tags: ['toan'] },
    { title: 'Luyện tập tìm vị trí', desc: 'Xác định vị trí trên - dưới, trong - ngoài, trước - sau của đồ vật.', tags: ['toan'] },
    { title: 'Đếm số trong tranh', desc: 'Đếm số lượng đồ vật xuất hiện trong tranh minh hoạ.', tags: ['toan'] },
    { title: 'Hoàn thiện dãy số', desc: 'Điền số còn thiếu để hoàn thiện dãy số theo đúng thứ tự.', tags: ['toan'] },
    { title: 'Học đếm từ 1 đến 10', desc: 'Làm quen và luyện đếm các con số từ 1 đến 10.', tags: ['toan'] },
    { title: 'Luyện viết các chữ số', desc: 'Tập viết đúng nét các chữ số theo hướng dẫn.', tags: ['tap-to'] },
    { title: 'Tìm và tô màu số', desc: 'Tìm đúng chữ số theo yêu cầu và tô màu sinh động.', tags: ['to-mau', 'toan'] },
    { title: 'Các cặp chữ cái dễ gây nhầm lẫn', desc: 'Phân biệt các cặp chữ cái dễ nhầm lẫn như b/d, p/q.', tags: ['tap-to'] },
    { title: 'Hoàn thiện bảng chữ cái', desc: 'Điền chữ cái còn thiếu để hoàn thiện bảng chữ cái.', tags: ['tap-to'] },
    { title: 'Trò chơi tìm chữ cái', desc: 'Tìm chữ cái theo yêu cầu ẩn trong bảng chữ cái.', tags: ['tap-to'] },
    { title: 'Khéo tay, tinh mắt', desc: 'Rèn luyện sự khéo léo đôi tay và khả năng quan sát tinh tế.', tags: ['to-mau'] },
    { title: 'Tô màu theo số', desc: 'Tô màu theo đúng số quy định để hoàn thiện bức tranh.', tags: ['to-mau', 'toan'] },
    { title: 'Tô nét', desc: 'Luyện tô theo nét chấm mờ để rèn sự khéo léo của tay.', tags: ['tap-to'] },
  ];

  // Data demo cho sort: ngày đăng giảm dần theo index, lượt xem/tải xen kẽ để có thứ tự khác ngày đăng
  const BASE_DATE = new Date('2026-07-01');
  worksheets.forEach((sheet, i) => {
    const d = new Date(BASE_DATE);
    d.setDate(d.getDate() - i * 3);
    sheet.image = '/assets/images/worksheet-placeholder.svg';
    sheet.date = d.toISOString().slice(0, 10);
    sheet.views = ((i * 53 + 120) % 850) + 60;
  });
%>
<section class="worksheet-list" data-worksheet-list>
  <div class="worksheet-list__inner">
    <h1 class="worksheet-list__title">Tài Liệu Mầm Non &amp; Tiền Tiểu Học</h1>
    <p class="worksheet-list__desc">Tuyển tập bài tập, phiếu luyện tập giúp bé mầm non &amp; tiền tiểu học làm quen với chữ, số và tư duy logic.</p>

    <p class="list-toolbar__active-tag" data-list-active-tag hidden>
      Đang lọc: <strong data-list-active-tag-label></strong>
      <button type="button" data-list-active-tag-clear aria-label="Bỏ lọc">✕</button>
    </p>

    <div class="list-toolbar">
      <div class="list-toolbar__view-toggle">
        <button type="button" class="is-active" data-view="grid" aria-label="Hiển thị dạng lưới">⊞ Lưới</button>
        <button type="button" data-view="list" aria-label="Hiển thị dạng danh sách">☰ Danh sách</button>
      </div>

      <div class="list-toolbar__search">
        <input type="text" class="list-toolbar__search-input" data-list-search placeholder="Tìm tài liệu...">
      </div>

      <div class="list-toolbar__sort">
        <select class="list-toolbar__sort-select" data-list-sort>
          <option value="date_desc">Mới đăng gần đây</option>
          <option value="views_desc">Lượt xem / tải nhiều nhất</option>
          <option value="title_asc">Tên tài liệu (A-Z)</option>
        </select>
      </div>
    </div>

    <p class="list-empty" data-worksheet-empty hidden>Không tìm thấy tài liệu phù hợp.</p>

    <div class="worksheet-list__row" data-worksheet-row>
      <% worksheets.forEach((sheet) => { %>
        <article class="worksheet-list__card">
          <a class="worksheet-list__card-link" href="#">
            <div class="worksheet-list__image">
              <img src="<%= sheet.image %>" alt="<%= sheet.title %>">
            </div>
            <div class="worksheet-list__body">
              <h3><%= sheet.title %></h3>
              <p><%= sheet.desc %></p>
            </div>
          </a>
        </article>
      <% }); %>
    </div>
  </div>
</section>

<script type="application/json" id="worksheet-list-data"><%- JSON.stringify(worksheets) %></script>
